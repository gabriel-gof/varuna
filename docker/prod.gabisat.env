# Production environment (gabisat instance template)

# Compose / multi-instance controls
VARUNA_ENV_FILE=docker/prod.gabisat.env
VARUNA_FRONTEND_BIND_IP=127.0.0.1
VARUNA_FRONTEND_HTTP_HOST_PORT=18080
VARUNA_BACKEND_BIND_IP=127.0.0.1
VARUNA_BACKEND_HOST_PORT=18081
# Used only when backend SSL mode is explicitly enabled.
VARUNA_TLS_CERTS_DIR=/etc/letsencrypt
VARUNA_DB_LIMIT_MEMORY=1G
VARUNA_DB_LIMIT_CPUS=1.0
VARUNA_REDIS_LIMIT_MEMORY=256M
VARUNA_REDIS_LIMIT_CPUS=0.5
VARUNA_BACKEND_LIMIT_MEMORY=2G
VARUNA_BACKEND_LIMIT_CPUS=2.0
VARUNA_FRONTEND_LIMIT_MEMORY=512M
VARUNA_FRONTEND_LIMIT_CPUS=0.5
VARUNA_GUNICORN_WORKERS=4
VARUNA_GUNICORN_THREADS=8
VARUNA_GUNICORN_TIMEOUT_SECONDS=120

DJANGO_SETTINGS_MODULE=varuna.settings
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-SECRET-KEY
DEBUG=False
ALLOWED_HOSTS=gabisat.example.com
CSRF_TRUSTED_ORIGINS=https://gabisat.example.com

# Django security
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=0
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1

# Django
DJANGO_MIGRATE=1
DJANGO_COLLECTSTATIC=1
ENABLE_SCHEDULER=1

# Database
DB_ENGINE=django.db.backends.postgresql
POSTGRES_DB=varuna_gabisat
POSTGRES_USER=varuna_gabisat
POSTGRES_PASSWORD=CHANGE-THIS-TO-A-STRONG-PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Cache TTLs
STATUS_CACHE_TTL=180
POWER_CACHE_TTL=60
OLT_LIST_CACHE_TTL=300
OLT_TOPOLOGY_LIST_CACHE_TTL=30
OLT_TOPOLOGY_DETAIL_CACHE_TTL=30

# SNMP
SNMP_WALK_TIMEOUT=3.0
SNMP_WALK_RETRIES=2
DISCOVERY_INTERVAL=14400
POLL_INTERVAL=300

# Apache
SERVER_NAME=gabisat.example.com
SERVER_ALIASES="gabisat.example.com"
WSGI_PROCESSES=4
WSGI_THREADS=15

# Frontend (Vite)
VITE_API_URL=/api

# Timezone
TZ=America/Sao_Paulo
