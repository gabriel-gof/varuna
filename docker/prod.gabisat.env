# Production environment (gabisat instance template)

# Compose / multi-instance controls
VARUNA_ENV_FILE=docker/prod.gabisat.env
VARUNA_FRONTEND_BIND_IP=127.0.0.1
VARUNA_FRONTEND_HTTP_HOST_PORT=18080
VARUNA_BACKEND_BIND_IP=127.0.0.1
VARUNA_BACKEND_HOST_PORT=18081
# standalone: varuna-db | shared mode: pg-varuna
VARUNA_POSTGRES_HOST=varuna-db
# Used only when backend SSL mode is explicitly enabled.
VARUNA_TLS_CERTS_DIR=/etc/letsencrypt
VARUNA_DB_LIMIT_MEMORY=1G
VARUNA_DB_LIMIT_CPUS=1.0
VARUNA_REDIS_LIMIT_MEMORY=256M
VARUNA_REDIS_LIMIT_CPUS=0.5
VARUNA_BACKEND_LIMIT_MEMORY=2G
VARUNA_BACKEND_LIMIT_CPUS=2.0
VARUNA_FRONTEND_LIMIT_MEMORY=512M
VARUNA_FRONTEND_LIMIT_CPUS=0.5
VARUNA_GUNICORN_WORKERS=4
VARUNA_GUNICORN_THREADS=8
VARUNA_GUNICORN_TIMEOUT_SECONDS=120

DJANGO_SETTINGS_MODULE=varuna.settings
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-SECRET-KEY
DEBUG=False
ALLOWED_HOSTS=varuna.gabisat.com.br
CSRF_TRUSTED_ORIGINS=https://varuna.gabisat.com.br

# Django security
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=0
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1

# Django
DJANGO_MIGRATE=1
DJANGO_COLLECTSTATIC=1
ENABLE_SCHEDULER=1

# Database
DB_ENGINE=django.db.backends.postgresql
POSTGRES_DB=varuna_gabisat
POSTGRES_USER=varuna_gabisat
POSTGRES_PASSWORD=CHANGE-THIS-TO-A-STRONG-PASSWORD
POSTGRES_HOST=varuna-db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Zabbix API
ZABBIX_API_URL=http://zabbix-web:8080/api_jsonrpc.php
ZABBIX_API_TIMEOUT_SECONDS=15
# Prefer dedicated API user (do not use personal admin account for automation).
ZABBIX_USERNAME=varuna_api
ZABBIX_PASSWORD=CHANGE-THIS-TO-A-VERY-STRONG-API-PASSWORD
# Optional: prefer token auth in production.
# ZABBIX_API_TOKEN=CHANGE-THIS-TO-A-LONG-RANDOM-TOKEN
ZABBIX_HOST_NAME_BY_OLT_JSON={}
ZABBIX_HOST_GROUP_NAME=Varuna/GabSAT
ZABBIX_HOST_GROUP_LEGACY_NAMES=OLT,OLTs,gabsat
ZABBIX_HOST_NAME_PREFIX=GabSAT-
ZABBIX_REFRESH_UPSTREAM_MAX_ITEMS=512
ZABBIX_AVAILABILITY_INTERVAL_SECONDS=30
ZABBIX_AVAILABILITY_STALE_SECONDS=45
ZABBIX_REFRESH_CLOCK_GRACE_SECONDS=15
ZABBIX_REFRESH_UPSTREAM_WAIT_SECONDS=12
ZABBIX_REFRESH_UPSTREAM_WAIT_STEP_SECONDS=2
ZABBIX_DISCONNECT_HISTORY_MAX_ITEMS=512
ZABBIX_DISCONNECT_WINDOW_MARGIN_SECONDS=90
ZABBIX_STATUS_STALE_MARGIN_SECONDS=90
COLLECTOR_CHECK_SECONDS=30
COLLECTOR_CHECK_MAX_BACKOFF_SECONDS=1800
TOPOLOGY_STRUCTURE_CACHE_TTL=43200

# Apache
SERVER_NAME=varuna.gabisat.com.br
SERVER_ALIASES="varuna.gabisat.com.br"
WSGI_PROCESSES=4
WSGI_THREADS=15

# Frontend (Vite)
VITE_API_URL=/api

# Timezone
TZ=America/Sao_Paulo
