# Shared infrastructure environment (single VM / multi-instance)
# Used by docker-compose.infra.shared.yml
# Tuned for: 4 CPU (AMD EPYC) / 16 GB RAM / SSD — high-throughput SNMP collection

# Shared network bind for host-exposed ports
VARUNA_SHARED_PG_BIND_IP=127.0.0.1

# Shared Varuna PostgreSQL (single container, many logical DBs)
VARUNA_SHARED_PG_BOOTSTRAP_DB=postgres
VARUNA_SHARED_PG_SUPERUSER=postgres
VARUNA_SHARED_PG_SUPERPASS=CHANGE-THIS-SHARED-POSTGRES-SUPERPASS
VARUNA_SHARED_PG_VARUNA_HOST_PORT=55432

# Shared Zabbix PostgreSQL
ZABBIX_POSTGRES_DB=zabbix
ZABBIX_POSTGRES_USER=zabbix
ZABBIX_POSTGRES_PASSWORD=CHANGE-THIS-ZABBIX-DB-PASSWORD
VARUNA_SHARED_PG_ZABBIX_HOST_PORT=55433

# ── Zabbix server process tuning ─────────────────────────────────
# Goal: maximize SNMP NVPs on 4 CPUs without excessive context switching.
# Previous total: 272 processes (120+40+80+32) — too many for 4 cores.
# New total: ~141 processes — SNMP-heavy, fewer idle regular pollers.
ZABBIX_WEB_HOST_PORT=8080
ZABBIX_SERVER_HOST_PORT=10051
ZBX_STARTPOLLERS=30
ZBX_STARTPOLLERSUNREACHABLE=15
ZBX_STARTSNMPPOLLERS=80
ZBX_STARTPREPROCESSORS=12
ZBX_STARTLLDPROCESSORS=4
ZBX_CACHESIZE=1G
ZBX_HISTORYCACHESIZE=256M
ZBX_HISTORYINDEXCACHESIZE=64M
ZBX_VALUECACHESIZE=256M
ZBX_TRENDCACHESIZE=32M
ZBX_HOUSEKEEPINGFREQUENCY=1
ZBX_MAXHOUSEKEEPERDELETE=100000
ZBX_TIMEOUT=10

# ── Zabbix user hardening (run by zabbix-hardening on every compose up) ──
ZABBIX_BOOTSTRAP_USERNAME=Admin
ZABBIX_BOOTSTRAP_PASSWORD=zabbix
ZABBIX_OPERATOR_USERNAME=gabriel
ZABBIX_OPERATOR_PASSWORD=CHANGE-THIS-ZABBIX-OPERATOR-PASSWORD
ZABBIX_VARUNA_USERNAME=varuna
ZABBIX_VARUNA_PASSWORD=CHANGE-THIS-ZABBIX-VARUNA-PASSWORD
ZABBIX_ENFORCED_ROLE_ID=3
ZABBIX_REMOVE_BOOTSTRAP_ADMIN=1
ZABBIX_HARDEN_WAIT_SECONDS=180
ZABBIX_HARDEN_WAIT_STEP_SECONDS=2

# ── Zabbix PostgreSQL tuning (write-heavy monitoring workload) ───
# Memory budget: ~4 GB for pg-zabbix (shared_buffers + connections + OS cache).
ZBX_PG_MAX_CONNECTIONS=150
ZBX_PG_SHARED_BUFFERS=2GB
ZBX_PG_EFFECTIVE_CACHE_SIZE=6GB
ZBX_PG_WORK_MEM=4MB
ZBX_PG_MAINTENANCE_WORK_MEM=512MB
ZBX_PG_MAX_WAL_SIZE=4GB
ZBX_PG_CHECKPOINT_COMPLETION_TARGET=0.9
ZBX_PG_RANDOM_PAGE_COST=1.1
# Write-throughput optimizations for monitoring data (acceptable micro-loss on crash)
ZBX_PG_SYNCHRONOUS_COMMIT=off
ZBX_PG_WAL_BUFFERS=64MB
ZBX_PG_CHECKPOINT_TIMEOUT=15min
ZBX_PG_EFFECTIVE_IO_CONCURRENCY=200
ZBX_PG_MIN_WAL_SIZE=1GB
ZBX_PG_WAL_COMPRESSION=on

# Timezone
TZ=America/Sao_Paulo
