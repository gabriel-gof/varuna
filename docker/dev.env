# Development environment

DJANGO_SETTINGS_MODULE=varuna.settings
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost:4000,http://localhost:8000

# Django
DJANGO_MIGRATE=1
DJANGO_COLLECTSTATIC=1
ENABLE_SCHEDULER=1
VARUNA_AUTH_BOOTSTRAP=1
VARUNA_AUTH_USERNAME=admin
VARUNA_AUTH_PASSWORD=admin
VARUNA_AUTH_ROLE=admin
VARUNA_AUTH_SUPERUSER=1
VARUNA_AUTH_FORCE_PASSWORD=1

# Database
DB_ENGINE=django.db.backends.postgresql
POSTGRES_DB=varuna_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=varuna-db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Zabbix API
ZABBIX_API_URL=http://zabbix-web:8080/api_jsonrpc.php
ZABBIX_API_TIMEOUT_SECONDS=15
ZABBIX_USERNAME=Admin
ZABBIX_PASSWORD=zabbix
ZABBIX_DB_ENABLED=1
ZABBIX_DB_NAME=zabbix
ZABBIX_DB_USER=zabbix
ZABBIX_DB_PASSWORD=zabbix
ZABBIX_DB_HOST=zabbix-db
ZABBIX_DB_PORT=5432
ZABBIX_HOST_NAME_BY_OLT_JSON={}
ZABBIX_HOST_GROUP_NAME=Varuna/Local
ZABBIX_HOST_GROUP_LEGACY_NAMES=OLT,OLTs,local server
ZABBIX_HOST_NAME_PREFIX=LOCAL-
ZABBIX_REFRESH_UPSTREAM_MAX_ITEMS=512
ZABBIX_AVAILABILITY_INTERVAL_SECONDS=30
ZABBIX_AVAILABILITY_STALE_SECONDS=45
ZABBIX_REFRESH_CLOCK_GRACE_SECONDS=15
ZABBIX_REFRESH_UPSTREAM_WAIT_SECONDS=12
ZABBIX_REFRESH_UPSTREAM_WAIT_STEP_SECONDS=2
ZABBIX_DISCONNECT_HISTORY_MAX_ITEMS=512
ZABBIX_DISCONNECT_WINDOW_MARGIN_SECONDS=90
ZABBIX_STATUS_STALE_MARGIN_SECONDS=90
POWER_LATEST_READS_HISTORY_FALLBACK_MAX_ITEMS=256
COLLECTOR_CHECK_SECONDS=30
COLLECTOR_CHECK_MAX_BACKOFF_SECONDS=1800
TOPOLOGY_STRUCTURE_CACHE_TTL=43200
UNM_DB_TIMEOUT_SECONDS=10

# Apache
SERVER_NAME=localhost
SERVER_ALIASES="localhost"
WSGI_PROCESSES=2
WSGI_THREADS=10

# Frontend (Vite)
VITE_API_URL=http://localhost:8000/api

# Timezone
TZ=America/Sao_Paulo
