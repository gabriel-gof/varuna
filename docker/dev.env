# Development environment

DJANGO_SETTINGS_MODULE=varuna.settings
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost:4000,http://localhost:8000

# Django
DJANGO_MIGRATE=1
DJANGO_COLLECTSTATIC=1

# Database
DB_ENGINE=django.db.backends.postgresql
POSTGRES_DB=varuna_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Cache TTLs
STATUS_CACHE_TTL=180
POWER_CACHE_TTL=60
OLT_LIST_CACHE_TTL=300

# SNMP
SNMP_WALK_TIMEOUT=3.0
SNMP_WALK_RETRIES=2
DISCOVERY_INTERVAL=3600
POLL_INTERVAL=300

# Apache
SERVER_NAME=localhost
SERVER_ALIASES="localhost"
WSGI_PROCESSES=2
WSGI_THREADS=10

# Frontend (Vite)
VITE_API_URL=http://localhost:8000/api

# Timezone
TZ=America/Sao_Paulo
