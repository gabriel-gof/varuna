# Production environment

DJANGO_SETTINGS_MODULE=varuna.settings
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-SECRET-KEY
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Django security
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=0
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1

# Django
DJANGO_MIGRATE=1
DJANGO_COLLECTSTATIC=1

# Database
DB_ENGINE=django.db.backends.postgresql
POSTGRES_DB=varuna_prod
POSTGRES_USER=varuna_prod
POSTGRES_PASSWORD=CHANGE-THIS-TO-A-STRONG-PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Cache TTLs
STATUS_CACHE_TTL=180
POWER_CACHE_TTL=60
OLT_LIST_CACHE_TTL=300

# SNMP
SNMP_WALK_TIMEOUT=3.0
SNMP_WALK_RETRIES=2
DISCOVERY_INTERVAL=14400
POLL_INTERVAL=300

# Apache
SERVER_NAME=your-domain.com
SERVER_ALIASES="your-domain.com www.your-domain.com"
WSGI_PROCESSES=4
WSGI_THREADS=15

# Frontend (Vite)
VITE_API_URL=/api

# Timezone
TZ=America/Sao_Paulo
